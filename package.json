{
  "name": "timeline-log",
  "version": "0.1.0",
  "description": "Desktop timeline log for company, institution, and role history.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./out/main/index.js",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "pnpm ensure:electron && pnpm rebuild:electron && electron-vite dev",
    "build": "pnpm rebuild:electron && electron-vite build",
    "package:win": "pnpm build && electron-builder --win --x64 --publish never",
    "preview": "pnpm ensure:electron && pnpm rebuild:electron && electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --deny-warnings",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "pnpm rebuild:node && vitest run",
    "test:watch": "vitest",
    "e2e": "pnpm ensure:electron && pnpm build && playwright test",
    "ensure:electron": "node node_modules/electron/install.js",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "postinstall": "pnpm ensure:electron && pnpm rebuild:electron"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "drizzle-kit": "^0.31.0",
    "electron": "^40.10.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.0",
    "oxlint": "^1.67.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.0",
    "typescript": "^6.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
